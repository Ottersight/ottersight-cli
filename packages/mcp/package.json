{
  "name": "@ottersight/mcp",
  "version": "0.1.3",
  "type": "module",
  "description": "OtterSight MCP server - security vulnerability scanning for AI assistants",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ottersight/ottersight-cli",
    "directory": "packages/mcp"
  },
  "bin": {
    "ottersight-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": ["dist", "SKILL.md"],
  "publishConfig": { "access": "public" },
  "engines": { "node": ">=20" },
  "mcpName": "io.github.ottersight/ottersight",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ottersight/scanner": "workspace:*",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.8.2"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  }
}

#!/usr/bin/env bash
# Pre-push hook: block internal/confidential content from reaching the public repo.
# Install: git config core.hooksPath .githooks
#
# Only scans ADDITIONS (lines starting with +), not deletions.
# This prevents false positives when removing confidential content.

set -euo pipefail

BLOCKED_PATTERNS=(
  "DO NOT PUBLISH"
  "internal strategy"
  "launch angle"
  "posting guidelines"
  "soft launch plan"
)

BLOCKED_PATHS=(
  "docs/launch/"
  "docs/internal/"
  "docs/strategy/"
)

BLOCKED_EXTENSIONS=(
  ".draft.md"
  ".internal.md"
)

echo "Pre-push: scanning for confidential content..."

ERRORS=0

# Get the diff of what's being pushed (additions only)
UPSTREAM=$(git rev-parse @{upstream} 2>/dev/null || echo "")
if [ -z "$UPSTREAM" ]; then
  # No upstream — first push, diff against empty tree
  DIFF_ADDED=$(git diff --diff-filter=A --name-only HEAD 2>/dev/null || true)
  DIFF_CONTENT=$(git log --format="" -p HEAD 2>/dev/null | grep "^+" | grep -v "^+++" || true)
else
  DIFF_ADDED=$(git diff --name-only "$UPSTREAM"..HEAD 2>/dev/null || true)
  DIFF_CONTENT=$(git diff "$UPSTREAM"..HEAD 2>/dev/null | grep "^+" | grep -v "^+++" || true)
fi

# Check new/modified files for blocked paths
for pattern in "${BLOCKED_PATHS[@]}"; do
  MATCHES=$(echo "$DIFF_ADDED" | grep -i "$pattern" || true)
  if [ -n "$MATCHES" ]; then
    echo "BLOCKED: Files in '$pattern' being added:"
    echo "$MATCHES"
    ERRORS=$((ERRORS + 1))
  fi
done

# Check new/modified files for blocked extensions
for ext in "${BLOCKED_EXTENSIONS[@]}"; do
  MATCHES=$(echo "$DIFF_ADDED" | grep -i "$ext" || true)
  if [ -n "$MATCHES" ]; then
    echo "BLOCKED: File with extension '$ext' being added:"
    echo "$MATCHES"
    ERRORS=$((ERRORS + 1))
  fi
done

# Check added lines for blocked text patterns
for pattern in "${BLOCKED_PATTERNS[@]}"; do
  if echo "$DIFF_CONTENT" | grep -qi "$pattern"; then
    echo "BLOCKED: Text pattern '$pattern' found in added lines"
    ERRORS=$((ERRORS + 1))
  fi
done

if [ "$ERRORS" -gt 0 ]; then
  echo ""
  echo "Push rejected: $ERRORS confidential content pattern(s) detected."
  echo "If this is intentional, use: git push --no-verify"
  exit 1
fi

echo "Pre-push: clean — no confidential content detected."
exit 0
